# Application
APP_NAME=rixin-contract-extract
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://app:app_password@localhost:5432/contract_extract

# Extraction providers (mock / ppocr / qwen)
OCR_PROVIDER=mock
LLM_PROVIDER=mock
PPOCR_URL=http://10.8.7.76:8081/ocr
PPOCR_TIMEOUT=60
PPOCR_PDF_TEXT_MIN_CHARS=100
PPOCR_PDF_TEXT_PAGE_RATIO=0.8
PPOCR_PDF_DPI=200
PPOCR_PAGE_CONCURRENCY=3
upload_dir=uploads/contracts
max_file_size=104857600
