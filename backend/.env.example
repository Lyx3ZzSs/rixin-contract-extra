# Application
APP_NAME=rixin-contract-extract
DEBUG=true

# Database (SQLite for local/single-machine; switch to PostgreSQL URL for multi-host)
DATABASE_URL=sqlite+aiosqlite:///./data/contract_extract.db

# OCR providers (mock / ppocr / ppstructurev3)
# Production OCR provider: ppstructurev3 (layout/tables) | ppocr (text-only) | mock
OCR_PROVIDER=ppstructurev3
LLM_PROVIDER=qwen
# LLM base_url must end at /v1 — the OpenAI SDK appends /chat/completions.
LLM_API_URL=http://10.10.10.245:8000/v1
LLM_API_KEY=

PPOCR_URL=http://10.8.7.76:8081/ocr
PPOCR_TIMEOUT=60
PPOCR_PDF_TEXT_MIN_CHARS=100
PPOCR_PDF_TEXT_PAGE_RATIO=0.8
PPOCR_PDF_DPI=200
PPOCR_PAGE_CONCURRENCY=3

# PP-StructureV3 layout-aware OCR service (PaddleOCR 3.0 / PaddleX serving)
PPSTRUCTUREV3_URL=http://10.8.7.76:8081/layout-parsing

# Long-contract chunking: pages per LLM call (1-page overlap)
LLM_CHUNK_PAGES=6
upload_dir=uploads/contracts
max_file_size=104857600

# Minimum auth: comma-separated valid API keys. Empty = open (dev only!).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEYS=
# CORS allowed origins (comma-separated). Empty = allow any.
ALLOWED_ORIGINS=
