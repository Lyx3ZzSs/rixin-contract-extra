# Application
APP_NAME=rixin-contract-extract
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://app:app_password@localhost:5432/contract_extract

# Extraction providers (mock / paddle / openai / deepseek / qwen)
OCR_PROVIDER=mock
LAYOUT_PROVIDER=mock
LLM_PROVIDER=mock
upload_dir=uploads/contracts
max_file_size=104857600
